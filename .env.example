# ── Turso Database
# Dapatkan dari: https://turso.tech/app → pilih database → "Connect" → "Get connection string"
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ── JWT Secret
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# ── Token Expiry (opsional, nilai default sudah disediakan)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Vercel (opsional, diisi otomatis oleh Vercel)
NEXT_PUBLIC_APP_VERSION=1.0.0
